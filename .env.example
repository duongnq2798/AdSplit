# Supabase Configuration
# Reference schema.sql in /supabase/schema.sql for the database setup.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Circle Developer Platform Configuration
# Get your API key from the Circle Developer Console: https://console.circle.com/
NEXT_PUBLIC_CIRCLE_API_KEY=sandbox_key
NEXT_PUBLIC_CIRCLE_ENTITY_SECRET=your-entity-secret-here

DEPLOYER_PRIVATE_KEY=